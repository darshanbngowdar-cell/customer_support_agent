APP_ENV=development
LOG_LEVEL=INFO

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

EMBEDDING_PROVIDER=sentence_transformers
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2

DATA_DIR=data/raw
VECTOR_STORE_DIR=data/vector_store
CHROMA_COLLECTION_NAME=support_knowledge_base
CHUNK_SIZE=900
CHUNK_OVERLAP=150
MIN_CHUNK_SIZE=450
MAX_CHUNK_SIZE=1400
SMALL_DOCUMENT_THRESHOLD=1800
LARGE_DOCUMENT_THRESHOLD=9000
RETRIEVAL_TOP_K=4
DENSE_TOP_K=8
BM25_TOP_K=8
FUSION_TOP_K=4
RRF_K=60
DENSE_WEIGHT=1.0
BM25_WEIGHT=1.0
RETRIEVAL_CONFIDENCE_THRESHOLD=0.35

ESCALATION_LOW_CONFIDENCE_THRESHOLD=0.35
ESCALATION_MAX_UNRESOLVED_TURNS=2
ESCALATION_SENSITIVE_KEYWORDS=billing,refund,legal,account deletion,security breach
ESCALATION_BILLING_KEYWORDS=billing,invoice,refund,charge,payment,subscription
ESCALATION_LEGAL_KEYWORDS=legal,lawsuit,compliance,contract,liability,terms of service,gdpr
ESCALATION_ACCOUNT_KEYWORDS=account deletion,delete my account,security breach,compromised,hacked,2fa,mfa,personal data

MEMORY_MAX_TURNS=12
MEMORY_TOKEN_BUDGET=1600
